
*Configuration
{
	Debug "Debug Config"
	Release "Release Config"
}

*Platform
{
	TestPlatform "Test platform"
}

*Architecture
{
	TestArch "Test architecture"
}

%GenerateFile "TestFile"
{
	Type
	{
		CTest: {
			Value: string
			, OptionalValue?: string
		}
	}
	Property
	{
		fg_TestTernary function(type(CTest) _TestValue) string
		fg_TestTernary `@(_TestValue<Value>)@(_TestValue->HasMember("OptionalValue") ? _TestValue<OptionalValue> : "Nope")`

		TestTernary1: string
		TestTernary1 true ? "Yes" : "No"

		fg_TestTernary2 function(bool _bValue) string
		fg_TestTernary2 _bValue ? "Yes" : "No"

		fg_TestTernary3 function(bool _bValue) {Value: string}
		fg_TestTernary3 {
			Value: _bValue ? "Yes" : "No"
		}

		fg_TestTernary4 function(bool _bValue) string
		fg_TestTernary4 (_bValue ? {Value: "Yes"} : {Value: "No"}) <Value>

		TestTernaryCompound1: string = 1.0 + 2.0 > 2.0 ? "Yes" : "No"
		TestTernaryCompound2: string = 1.0 > 2.0 || 3.0 < 4.0 ? "Yes" : "No"
		TestTernaryCompound3: string = 1.0 < 2.0 && 3.0 > 4.0 ? "Yes" : "No"
		TestTernaryRecursive1: string = (false ? false : true) ? "Yes" : "No"
		TestTernaryRecursive2: string = true ? (false ? "No" : "Yes") : "No"
		TestTernaryRecursive3: string = false ? "No" : (false ? "No" : "Yes")
		TestTernaryRecursive4: string = false ? "No" : false ? "No" : "Yes"
		TestTernaryNestedBinaryOperand: string = (true && {Value: false ? "No" : "Yes"})->EJsonToString("")

		TestObject: type(CTest) = {Value: "Test"}
		TestObject2: type(CTest) = {Value: "Test", OptionalValue: "Yep"}
	}
	GenerateFile
	{
		Name `@(BuildSystemOutputDir)/TestGenerateFile.txt`
		Contents	`Generate File Contents:\n`\
					`@(fg_TestTernary(TestObject))\n`\
					`@(fg_TestTernary(TestObject2))\n`\
					`@(fg_TestTernary2(true))\n`\
					`@(fg_TestTernary2(false))\n`\
					`@(fg_TestTernary3(true)->ToString()->Trim())\n`\
					`@(fg_TestTernary3(false)->ToString()->Trim())\n`\
					`@(fg_TestTernary4(true))\n`\
					`@(fg_TestTernary4(false))\n`\
					`@(TestTernary1)\n`\
					`@(TestTernaryCompound1)\n`\
					`@(TestTernaryCompound2)\n`\
					`@(TestTernaryCompound3)\n`\
					`@(TestTernaryRecursive1)\n`\
					`@(TestTernaryRecursive2)\n`\
					`@(TestTernaryRecursive3)\n`\
					`@(TestTernaryRecursive4)\n`\
					`@(TestTernaryNestedBinaryOperand)\n`

		Executable false
		UnixLineEnds true
		UnicodeBOM false
	}
}
