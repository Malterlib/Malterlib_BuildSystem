
*Configuration
{
	Debug "Debug Config"
	Release "Release Config"
}

*Platform
{
	TestPlatform "Test platform"
}

*Architecture
{
	TestArch "Test architecture"
}

%GenerateFile "TestFile"
{
	Property
	{
		CalcValue function(string _Test, string? _Inner, bool? _bAppend) {
			Test: string
			, TestOptional?: {
				InnerValue: string
			}
			, TestOptional.InnerValue?: string
		}

		GetDefaulted function(any _Value, any _Default) any
		GetDefaulted _Default
		{
			!!_Value undefined
		}
		GetDefaulted _Value
		{
			!_Value undefined
		}

		CalcValue {
			Test: _Test
			, TestOptional: {
				InnerValue: GetDefaulted(_Inner, "Default")
			}
			, "TestOptional.InnerValue": "Not inner"
		}

		CalcValue #<Test> =+ " Appended"
		{
			!!_bAppend true
		}
		TestEllipsis function(string _Test, any ...p_Inner) string
		TestEllipsis `@(_Test) @(Format("{} {} {}", p_Inner...))`
		TestValues: [any] = ["Test", 2, "6"]
	}
	GenerateFile
	{
		Name `@(BuildSystemOutputDir)/TestGenerateFile.txt`
		Contents 	`Generate File Contents:\n`\
					`@(CalcValue("Test 1")->ToString())\n`\
					`@(CalcValue("Test 2", "Inner 1")->ToString())\n`\
					`@(CalcValue("Test 3", "Inner 1", true)->ToString())\n`\
					`@(TestEllipsis("Test 4", TestValues...))\n`
		Executable false
		UnixLineEnds true
		UnicodeBOM false
	}
}
