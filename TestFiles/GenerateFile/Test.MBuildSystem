
*Configuration
{
	Debug "Debug Config"
	Release "Release Config"
}

*Platform
{
	TestPlatform "Test platform"
}

*Architecture
{
	TestArch "Test architecture"
}

%GenerateFile "TestFile"
{
	GenerateFile
	{
		Name `@(BuildSystemOutputDir)/TestGenerateFile.txt`
		Contents "Generate File Contents"
		Executable false
		UnixLineEnds true
		UnicodeBOM false
	}
}
