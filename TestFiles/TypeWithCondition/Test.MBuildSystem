
*Configuration
{
	Debug "Debug Config"
	Release "Release Config"
}

*Platform
{
	TestPlatform "Test platform"
}

*Architecture
{
	TestArch "Test architecture"
}

Type
{
	CTest: {
		Test: string
		, TestOptional?: string
	}
	{
		 !!Platform "Invalid"
	}
}

%GenerateFile "TestFile"
{
	Property
	{
		Test: bool = false

		TestFunction function(any _Value, any _Default) type(CTest) = {Test: "Test"}
	}
	GenerateFile
	{
		Name `@(BuildSystemOutputDir)/TestGenerateFile.txt`
		Contents 	`Generate File Contents:\n`\
					`@(TestFunction(1, 2)<Test>)\n`
		Executable false
		UnixLineEnds true
		UnicodeBOM false
	}
}
