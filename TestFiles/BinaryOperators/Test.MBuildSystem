
*Configuration
{
	Debug "Debug Config"
	Release "Release Config"
}

*Platform
{
	TestPlatform "Test platform"
}

*Architecture
{
	TestArch "Test architecture"
}

%GenerateFile "TestFile"
{
	Property
	{
		Value1: float = 5.0
		Value2: float = 2.5
		Value3: float = 6.0
		Value4: [string]?
		TestValueString: string = `@((Value1 / Value2)->EJsonToString(""))`
		TestValue: float = Value1 / Value2 + Value3
		TestValue2: float = Value1 / Value2 + 7.0
		TestValue3: string = "Path0" / "Path1"
		TestValue4: float = Value1 + 5.0 / Value2
		TestValue5: float = Value1 + (5.0 / Value2)
		TestValue6: float = (Value1 + 5.0) / Value2
		TestValue7: float = 10.0 / 5.0 + 20.0 / 10.0 + 1.0
		TestValue8: float = Value1 / (5.0 + Value2)
		TestValue9: float = (Value1 / 5.0) + Value2
		TestValue10: float = Value1 / 5.0 + Value2
		TestValue11: float = 1.0 + 10.0 / 5.0 + 20.0 / 10.0 + 1.0
		TestValue12: bool = 1.0 < 2.0
		TestValue13: bool = 1.0 + 3.0 * 5.0 < 2.0 * 3.0
		TestValue14: float = 1.0 + 3.0 * 5.0
		TestValue15: int = 1 | 2
		TestValue16: int = 3 & 1
		TestValue17: int = 3 ^ 1
		TestValue18: int = 1 << 2
		TestValue19: int = 8 >> 2
		TestValue20: bool = 1.0 < 2.0 && 1.0 < 3.0
		TestValue21: bool = 3.0 < 2.0 || 1.0 < 3.0
		TestValue22: bool = !true
		TestValue23: int = ~3
		TestValue24: int = +3
		TestValue25: int = -3
		TestValue26: float = +3.0
		TestValue27: float = -3.0
		TestValue28: bool = !5 < !!6
		TestValue29: bool = !(5 < 6)
		TestValue30: [string] = (Value4 || ["Test"])
		TestValue31: [string] = (["Test"] && ["Test2"])
		TestValue32: bool = (true || Error("Should Not Eval"))
		TestValue33: bool = (false && Error("Should Not Eval"))
		TestValue34: {...: string} = {Value: "Path0"->Trim() / "Path1", Value2: "Test"}
		TestValue35: string = "" ?? Error("Should Not Eval")
		TestValue36: bool = true ?? Error("Should Not Eval")
		TestValue37: bool = false ?? Error("Should Not Eval")
		TestValue38: string = null ?? "Null"
		TestValue39: string = undefined ?? "Undefined"
		TestValue40: string = ("" ?? Error("Should Not Eval"))
		TestValue41: bool = (true ?? Error("Should Not Eval"))
		TestValue42: bool = (false ?? Error("Should Not Eval"))
		TestValue43: string = (null ?? "Null")
		TestValue44: string = (undefined ?? "Undefined")
	}
	GenerateFile
	{
		Name BuildSystemOutputDir / "TestGenerateFile.txt"
		Contents	`Generate File Contents:\n`\
					`@(TestValueString)\n`\
					`@(TestValue->EJsonToString(""))\n`\
					`@(TestValue2->EJsonToString(""))\n`\
					`@(TestValue3)\n`\
					`@(TestValue4->EJsonToString(""))\n`\
					`@(TestValue5->EJsonToString(""))\n`\
					`@(TestValue6->EJsonToString(""))\n`\
					`@(TestValue7->EJsonToString(""))\n`\
					`@(TestValue8->EJsonToString(""))\n`\
					`@(TestValue9->EJsonToString(""))\n`\
					`@(TestValue10->EJsonToString(""))\n`\
					`@(TestValue11->EJsonToString(""))\n`\
					`@(TestValue12->EJsonToString(""))\n`\
					`@(TestValue13->EJsonToString(""))\n`\
					`@(TestValue14->EJsonToString(""))\n`\
					`@(TestValue15->EJsonToString(""))\n`\
					`@(TestValue16->EJsonToString(""))\n`\
					`@(TestValue17->EJsonToString(""))\n`\
					`@(TestValue18->EJsonToString(""))\n`\
					`@(TestValue19->EJsonToString(""))\n`\
					`@(TestValue20->EJsonToString(""))\n`\
					`@(TestValue21->EJsonToString(""))\n`\
					`@(TestValue22->EJsonToString(""))\n`\
					`@(TestValue23->EJsonToString(""))\n`\
					`@(TestValue24->EJsonToString(""))\n`\
					`@(TestValue25->EJsonToString(""))\n`\
					`@(TestValue26->EJsonToString(""))\n`\
					`@(TestValue27->EJsonToString(""))\n`\
					`@(TestValue28->EJsonToString(""))\n`\
					`@(TestValue29->EJsonToString(""))\n`\
					`@(TestValue30->EJsonToString(""))\n`\
					`@(TestValue31->EJsonToString(""))\n`\
					`@(TestValue32->EJsonToString(""))\n`\
					`@(TestValue33->EJsonToString(""))\n`\
					`@(TestValue34->EJsonToString(""))\n`\
					`@(TestValue35->EJsonToString(""))\n`\
					`@(TestValue36->EJsonToString(""))\n`\
					`@(TestValue37->EJsonToString(""))\n`\
					`@(TestValue38->EJsonToString(""))\n`\
					`@(TestValue39->EJsonToString(""))\n`\
					`@(TestValue40->EJsonToString(""))\n`\
					`@(TestValue41->EJsonToString(""))\n`\
					`@(TestValue42->EJsonToString(""))\n`\
					`@(TestValue43->EJsonToString(""))\n`\
					`@(TestValue44->EJsonToString(""))\n`

		Executable false
		UnixLineEnds true
		UnicodeBOM false
	}
}
